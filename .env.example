VITE_API_BASE_URL=https://api.themoviedb.org/
VITE_API_VERSION=3

VITE_API_KEY=
VITE_IMAGE_BASE_URL=https://image.tmdb.org/t/p/
VITE_API_ACCESS_TOKEN=

# Force the anti-inspect guard on in `yarn dev` (it is always on in production).
# Leave unset / 0 for normal dev. Set to 1 to test right-click block, DevTools
# detection, console muting, etc. without doing a full production build.
VITE_ANTI_INSPECT=0